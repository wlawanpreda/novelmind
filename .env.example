# ===== ANSRE Environment (คัดลอกเป็น .env แล้วเติมค่า) =====

# --- Cloud APIs ---
GEMINI_API_KEY=your_gemini_key_here
NOTION_TOKEN=your_notion_token_here
# ELEVENLABS_API_KEY=          # optional, TTS พรีเมียม

# --- LLM routing (ดู MACMINI_SETUP.md) ---
# gemini  = ใช้ Gemini ล้วน (เดิม)
# local   = ใช้ Mac mini ล้วน (ประหยัดสุด)
# hybrid  = เขียนร้อยแก้วใช้ Gemini, งานอื่นใช้ local (แนะนำ)
LLM_BACKEND=hybrid

# ปลายทาง LLM ภายในบ้าน (Ollama / LM Studio)
LOCAL_LLM_BASE_URL=http://macmini.local:11434/v1
LOCAL_LLM_MODEL=qwen2.5:14b
LOCAL_LLM_MODEL_HEAVY=qwen2.5:32b
LOCAL_LLM_API_KEY=ollama
LOCAL_LLM_TIMEOUT=600

# override รายบทบาท (ไม่จำเป็น) เช่นบังคับ outline ให้ใช้ gemini:
# LLM_ROLE_OUTLINE=gemini
# LLM_ROLE_WRITER=local

# --- Image generation (รูปปก) routing — ดู MACMINI_IMAGE_SETUP.md ---
# gemini = Imagen เสมอ (เสียเงิน, ของเดิม)
# local  = ComfyUI บน Mac mini ล้วน (ฟรี)
# hybrid = ลอง Mac mini ก่อน ดับแล้ว fallback Imagen (แนะนำเมื่อตั้ง Mac mini แล้ว)
IMAGE_BACKEND=gemini
LOCAL_IMAGE_BASE_URL=http://macmini.local:8188   # ComfyUI default port 8188
LOCAL_IMAGE_MODEL=sd_xl_base_1.0.safetensors
LOCAL_IMAGE_STEPS=30
LOCAL_IMAGE_CFG=7.0
# LOCAL_IMAGE_NEGATIVE=text, watermark, signature, blurry, lowres, deformed
LOCAL_IMAGE_TIMEOUT=600
# RAM ตึง? (เช่น Mac mini 24GB รัน Ollama+SDXL พร้อมกัน) ลดขนาดภาพ+steps:
# LOCAL_IMAGE_DIM_SCALE=0.75   # 1.0=1024px · 0.75=768px (เร็วขึ้น/กิน RAM น้อยลง)
# LOCAL_IMAGE_STEPS=22

# --- ANSRE Gateway (HTTP service ห่อ LLM+Image) — ดู SERVICE_ARCHITECTURE.md ---
# ฝั่ง client: ชี้ไป gateway แล้วใช้ ansre_client.Ansre() เรียก (ไม่ต้องถือคีย์เอง)
# ANSRE_GATEWAY_URL=http://macmini.local:9000
# ANSRE_GATEWAY_TOKEN=                 # ต้องตรงกับฝั่ง gateway (macmini_gateway_setup.sh สุ่มให้)
# ฝั่ง gateway (ตั้งบน Mac mini ผ่าน launchd):
# ANSRE_GATEWAY_WORKERS=1              # 1 = serialize งาน image (แนะนำบนเครื่อง RAM ตึง)
# ANSRE_FREE_LLM_BEFORE_IMAGE=1        # ปลด Ollama ก่อนเรนเดอร์ (คืน RAM)

# Circuit breaker — Gemini ล้ม/throttle ต่อเนื่อง N ครั้ง → พัก แล้วเด้งไป local อัตโนมัติ
GEMINI_FAIL_THRESHOLD=3
GEMINI_COOLDOWN_SEC=120
# Auto-pacing — เว้นจังหวะขั้นต่ำ (วินาที) ระหว่างเรียก Gemini กัน rate-limit
# 0=ปิด · แนะนำ 6-8 ถ้าผลิตหลายเรื่องรวดโดยยังไม่มี Mac mini local
ANSRE_CALL_GAP=0
# ความยาวต่อฉาก (คุมไม่ให้บทยาวเกิน)
ANSRE_SCENE_WORDS=450

# --- คุมค่าใช้จ่าย (Phase 3) ---
# เพดานค่า Gemini ต่อวัน (USD); 0 = ไม่จำกัด. เกินแล้ว reroute ไป local อัตโนมัติ
ANSRE_DAILY_USD_CAP=0
# ดู usage: python llm_provider.py --usage   (ledger: SecondBrain/llm_usage.jsonl)

# --- Orchestrator (รันต่อเนื่อง Phase 1-2) ---
ANSRE_MIN_POOL=3
ANSRE_SCOUT_EVERY_HOURS=12
ANSRE_SCOUT_LIMIT=2
ANSRE_LOOP_SLEEP=1800
ANSRE_TEASER_DURATION=60

# --- คุณภาพการเขียน (ใช้กับ backend gemini) ---
# master = pro ทุก stage | premium = pro เฉพาะเขียน/เกลา | draft = flash หมด
WRITING_MODE=premium

# --- Auto-Publishing (Phase 4) — ดู PUBLISHING.md ---
PUBLISH_YOUTUBE=0
YOUTUBE_TOKEN_FILE=youtube_token.json
YOUTUBE_PRIVACY=unlisted
PUBLISH_TIKTOK=0
# TIKTOK_ACCESS_TOKEN=
PUBLISH_NOVEL=0

# --- TTS ---
# edge-tts (ฟรี,เน็ต) | macos (ฟรี,offline) | gtts | elevenlabs
TTS_ENGINE=edge-tts
